// VerilogA for BIAS, bias, veriloga

`include "disciplines.vams"
`include "constants.vams"

module bias(vdda, gnda, vbg_in, ibias_in, resext, en, iout1, iout2, vref_out);
    
    // ================= Port Declarations =================
    inout vdda, gnda;      // Power supply and ground
    inout vbg_in;          // Bandgap reference input (nominal 1.27V)
    inout ibias_in;        // Op-amp bias input (required for internal op-amp operation)
    inout resext;          // External reference resistor pin (for V-to-I conversion)
    inout en;              // Enable/Reset signal (Active high to enable, low for power-down)
    
    inout iout1, iout2;    // Two source current outputs
    inout vref_out;        // VDD/2 reference voltage output
    
    // Declare ports as electrical nodes
    electrical vdda, gnda, vbg_in, ibias_in, resext, en, iout1, iout2, vref_out;
    
    // ================= Parameter Definitions =================
    parameter real vth_en  = 0.9;  // Threshold voltage for the enable signal
    parameter real M1      = 1.0;  // Current mirror ratio for iout1
    parameter real M2      = 2.0;  // Current mirror ratio for iout2
    
    parameter real R_out_v = 100;  // Equivalent output resistance for voltage buffer
    parameter real R_out_i = 100G; // Equivalent parallel resistance for current sources (idealized)

    // Internal variables
    real vbg_val, en_val, vdd_val, ibias_val;
    real i_ref;
    real target_vref;

    analog begin
        // Read real-time voltage levels at input nodes
        vbg_val   = V(vbg_in, gnda);
        vdd_val   = V(vdda, gnda);
        en_val    = V(en, gnda);
        ibias_val = V(ibias_in, gnda);
        
        // [Mixed-Signal Enhancement]: Use 'cross' to accurately detect threshold crossings
        // Syntax: @(cross( expression, direction ))
        // Direction 0 means it triggers on both rising (+1) and falling (-1) edges.
        // This forces the simulator to calculate a time step exactly when en_val crosses vth_en.
        @(cross(en_val - vth_en, 0));
        
        // Accurately capture the moment bandgap voltage crosses 0.1V (startup)
        @(cross(vbg_val - 0.1, +1)); 

        // Simulate a tiny leakage current to ground for the internal op-amp bias pin
        // This prevents floating node errors in the simulator
        I(ibias_in, gnda) <+ V(ibias_in, gnda) / 50k;

        // ================= Core State Machine: Active vs. Power-Down =================
        // Active condition: EN is high AND Bandgap is ready AND Bias is present
        if ((en_val > vth_en) && (vbg_val > 0.1) && (ibias_val > 0.1)) begin
            
            // 1. V-to-I Conversion Logic
            // The internal op-amp forces the bandgap voltage across the external resistor
            V(resext, gnda) <+ vbg_val;
            
            // Measure the actual current flowing through the external resistor
            // Use max() to prevent negative oscillating currents during transient simulation
            i_ref = abs(I(resext, gnda));
            
            // 2. Target Voltage Output (Tracks VDDA/2)
            target_vref = vdd_val / 2.0;
            
        end else begin
            // [Power-Down Mode]: Enter ultra-low power state
            // Release the RESEXT pin (equivalent to turning off the op-amp, high-Z)
            I(resext, gnda) <+ 0.0; 
            
            // Reset internal reference current and target voltage
            i_ref = 0.0;
            target_vref = 0.0;
        end

        // ================= Output Stage =================
        
        // 1. VDD/2 Reference Voltage Buffer Output (with load regulation / IR drop)
        I(vref_out, gnda) <+ (V(vref_out, gnda) - target_vref) / R_out_v;

        // 2. Multiple Source Current Outputs (PMOS Current Mirrors)
        // Note: Current flows from VDDA, out through the iout pins, into the external load
        I(vdda, iout1) <+ i_ref * M1;
        I(iout1, vdda) <+ V(iout1, vdda) / R_out_i; // Simulate finite output impedance

        I(vdda, iout2) <+ i_ref * M2;
        I(iout2, vdda) <+ V(iout2, vdda) / R_out_i;
        
    end
endmodule